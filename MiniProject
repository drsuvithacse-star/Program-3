def _make_student_doc(student_id: int, plagiarism_level: str) -> str:
    """
    plagiarism_level: 'none' | 'light' | 'moderate' | 'heavy'
    """
    rng = random.Random(student_id * 37 + 13)
    name = STUDENT_NAMES[student_id % len(STUDENT_NAMES)]
    roll = f"2024CS{student_id:03d}"
    topic_idx = student_id % len(UNIQUE_TOPICS)
    topic_name, topic_body = UNIQUE_TOPICS[topic_idx]

    intro = (
        f"Name: {name} | Roll No: {roll}\n\n"
        f"Assignment Report – {topic_name.title()}\n\n"
        f"Introduction\n\n"
        f"This report discusses the fundamental concepts related to {topic_name}. "
        f"The study of {topic_name} is essential in modern computer science education. "
        f"Understanding these principles helps in developing efficient software systems.\n\n"
    )

    # Pick definitions to include
    if plagiarism_level == "none":
        defs = rng.sample(SHARED_DEFINITIONS, 1)
    elif plagiarism_level == "light":
        defs = rng.sample(SHARED_DEFINITIONS, 2)
    elif plagiarism_level == "moderate":
        defs = rng.sample(SHARED_DEFINITIONS, 4)
    else:  # heavy
        defs = rng.sample(SHARED_DEFINITIONS, 6)

    defs_section = "Key Definitions\n\n" + "\n\n".join(defs) + "\n\n"

    # Pick copied paragraphs
    if plagiarism_level == "none":
        copied = []
    elif plagiarism_level == "light":
        copied = rng.sample(SHARED_COPIED_PARAGRAPHS, 1)
    elif plagiarism_level == "moderate":
        copied = rng.sample(SHARED_COPIED_PARAGRAPHS, 2)
    else:
        copied = rng.sample(SHARED_COPIED_PARAGRAPHS, 3)

    copied_section = ""
    if copied:
        copied_section = "Technical Background\n\n" + "\n\n".join(copied) + "\n\n"

    body = f"Main Discussion\n\n{topic_body}\n\n"

    conclusion = (
        f"Conclusion\n\n"
        f"This report presented an analysis of {topic_name} from a computer science perspective. "
        f"The algorithms and data structures studied in this course provide a solid foundation "
        f"for solving real-world computational problems. "
        f"Further study in this area will deepen understanding of {topic_name}.\n"
    )

    return intro + defs_section + copied_section + body + conclusion


def generate_corpus(num_docs: int = 20) -> dict[str, str]:
    """
    Returns {doc_id: text} for num_docs simulated student reports.
    Distribution: ~20% heavy, 30% moderate, 30% light, 20% none
    """
    rng = random.Random(42)
    levels = (
        ["heavy"] * max(1, num_docs // 5) +
        ["moderate"] * max(1, num_docs * 3 // 10) +
        ["light"] * max(1, num_docs * 3 // 10) +
        ["none"] * max(1, num_docs // 5)
    )
    # Pad/trim to exact length
    while len(levels) < num_docs:
        levels.append(rng.choice(["light", "moderate"]))
    levels = levels[:num_docs]
    rng.shuffle(levels)

    corpus = {}
    for i, level in enumerate(levels):
        doc_id = f"student_{i+1:03d}"
        corpus[doc_id] = _make_student_doc(i, level)
    return corpus
